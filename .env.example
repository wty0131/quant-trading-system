# ============================================================
# 量化交易系统 — 环境变量配置模板
# 复制此文件为 .env 并填入你的实际配置
# ============================================================

# --- 数据库 ---
DATABASE_PATH=./data/quant.db

# --- API Keys（可选，按需填入）---
# TUSHARE_TOKEN=your_tushare_token_here
# BINANCE_API_KEY=your_binance_api_key_here
# BINANCE_SECRET_KEY=your_binance_secret_key_here

# --- 网络代理（国内访问海外数据源时使用，可选）---
PROXY_SOCKS5=socks5://127.0.0.1:10808
PROXY_ENABLED=false

# --- QMT 实盘交易（可选，仅A股实盘时需要）---
QMT_PATH=your_qmt_install_path
QMT_ACCOUNT=your_account_id
QMT_MINI_MODE=true

# --- 运行环境 ---
ENV=development
LOG_LEVEL=DEBUG
