# ============================================================
# 量化交易系统 — 环境变量配置模板
# 复制此文件为 .env 并填入你的实际配置
# ============================================================

# --- 数据库 ---
DATABASE_PATH=./data/quant.db

# --- 网络代理（可选，按需填入）---
# PROXY_SOCKS5=socks5://127.0.0.1:10800
# PROXY_ENABLED=false

# --- QMT 实盘交易（可选，仅A股实盘时需要）---
QMT_PATH=your_qmt_install_path
QMT_ACCOUNT=your_account_id
QMT_MINI_MODE=true

# --- 运行环境 ---
ENV=development
LOG_LEVEL=DEBUG
