.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo

# 日志
logs/*.log

# OS
.DS_Store
Thumbs.db

# 回测输出
output/
results/

# 临时文件
*.tmp
*.bak
